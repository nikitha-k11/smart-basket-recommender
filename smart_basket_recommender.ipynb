# ============================================
# USER FEATURE ENGINEERING
# ============================================

# 1 — Order level stats per user
user_order_stats = prior_orders.groupby('user_id').agg(
    total_orders=('order_id', 'count'),
    avg_days_between_orders=('days_since_prior_order', 'mean'),
    avg_order_hour=('order_hour_of_day', 'mean'),
    preferred_day=('order_dow', lambda x: x.mode()[0])
).reset_index()

# 2 — Product level stats per user
user_product_stats = user_product_history.groupby('user_id').agg(
    total_items_bought=('product_id', 'count'),
    unique_products=('product_id', 'nunique'),
    reorder_rate=('reordered', 'mean'),
).reset_index()

# 3 — Nutrition profile per user
nutrition_profile = user_product_history.groupby(
    ['user_id', 'nutrition_category']
).size().unstack(fill_value=0).reset_index()
nutrition_profile.columns.name = None

# Rename columns safely
for col in ['healthy', 'junk', 'neutral']:
    if col not in nutrition_profile.columns:
        nutrition_profile[col] = 0

nutrition_profile = nutrition_profile.rename(columns={
    'healthy': 'healthy_count',
    'junk': 'junk_count',
    'neutral': 'neutral_count'
})
nutrition_profile['total_food'] = (
    nutrition_profile['healthy_count'] +
    nutrition_profile['junk_count']
)
nutrition_profile['healthy_ratio'] = (
    nutrition_profile['healthy_count'] /
    nutrition_profile['total_food'].replace(0, 1)
)

# 4 — Price tier profile per user
price_profile = user_product_history.groupby(
    ['user_id', 'price_tier']
).size().unstack(fill_value=0).reset_index()
price_profile.columns.name = None

for col in ['budget', 'mid', 'premium']:
    if col not in price_profile.columns:
        price_profile[col] = 0

price_profile = price_profile.rename(columns={
    'budget': 'budget_count',
    'mid': 'mid_count',
    'premium': 'premium_count'
})
price_profile['total_priced'] = (
    price_profile['budget_count'] +
    price_profile['mid_count'] +
    price_profile['premium_count']
)
price_profile['budget_ratio'] = (
    price_profile['budget_count'] /
    price_profile['total_priced'].replace(0, 1)
)
price_profile['premium_ratio'] = (
    price_profile['premium_count'] /
    price_profile['total_priced'].replace(0, 1)
)

# 5 — Merge everything into one user table
user_features = user_order_stats \
    .merge(user_product_stats, on='user_id') \
    .merge(nutrition_profile[['user_id', 'healthy_count',
                               'junk_count', 'healthy_ratio']], on='user_id') \
    .merge(price_profile[['user_id', 'budget_count',
                           'premium_count', 'budget_ratio',
                           'premium_ratio']], on='user_id')

print("User features shape:", user_features.shape)
print("\nSample:")
print(user_features.head(5).to_string())
print("\nColumns:", list(user_features.columns))


