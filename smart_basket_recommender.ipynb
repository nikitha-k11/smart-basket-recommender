from scipy.sparse import csr_matrix
from sklearn.neighbors import NearestNeighbors
import numpy as np

# ============================================
# STEP 1 — Build sparse matrix
# ============================================
# Map user_id and product_id to integer indices
user_ids = user_item_matrix['user_id'].unique()
product_ids = user_item_matrix['product_id'].unique()

user_to_idx = {u: i for i, u in enumerate(user_ids)}
product_to_idx = {p: i for i, p in enumerate(product_ids)}
idx_to_product = {i: p for p, i in product_to_idx.items()}

rows = user_item_matrix['user_id'].map(user_to_idx)
cols = user_item_matrix['product_id'].map(product_to_idx)
vals = user_item_matrix['purchase_count'].values

sparse_matrix = csr_matrix(
    (vals, (rows, cols)),
    shape=(len(user_ids), len(product_ids))
)

print("Sparse matrix shape:", sparse_matrix.shape)
print("Sparsity: {:.2f}%".format(
    100 * (1 - sparse_matrix.nnz / (sparse_matrix.shape[0] * sparse_matrix.shape[1]))
))

# ============================================
# STEP 2 — Train KNN model (user similarity)
# ============================================
knn_model = NearestNeighbors(
    metric='cosine',
    algorithm='brute',
    n_neighbors=20,
    n_jobs=-1
)
knn_model.fit(sparse_matrix)
print("\nKNN model trained on", sparse_matrix.shape[0], "users")

# ============================================
# STEP 3 — Recommendation function
# ============================================
def get_cf_recommendations(user_id, n_recommendations=20):
    """
    Given a user_id, find similar users
    and return products they bought that this user hasn't
    """
    if user_id not in user_to_idx:
        return []
    
    user_idx = user_to_idx[user_id]
    user_vector = sparse_matrix[user_idx]
    
    # Find similar users
    distances, indices = knn_model.kneighbors(
        user_vector, n_neighbors=11
    )
    
    # Get products bought by similar users
    similar_user_indices = indices.flatten()[1:]  # exclude self
    
    # Products this user already bought
    already_bought = set(
        user_item_matrix[user_item_matrix['user_id'] == user_id]['product_id']
    )
    
    # Score candidate products
    product_scores = {}
    for sim_idx, distance in zip(similar_user_indices, distances.flatten()[1:]):
        similarity = 1 - distance
        sim_user_id = user_ids[sim_idx]
        sim_products = user_item_matrix[
            user_item_matrix['user_id'] == sim_user_id
        ][['product_id', 'purchase_count']]
        
        for _, row in sim_products.iterrows():
            pid = row['product_id']
            if pid not in already_bought:
                if pid not in product_scores:
                    product_scores[pid] = 0
                product_scores[pid] += similarity * row['purchase_count']
    
    # Sort by score
    top_products = sorted(
        product_scores.items(), key=lambda x: x[1], reverse=True
    )[:n_recommendations]
    
    return top_products

# ============================================
# STEP 4 — Quick test
# ============================================
test_user = user_ids[0]
recs = get_cf_recommendations(test_user, n_recommendations=10)

