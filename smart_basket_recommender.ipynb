import numpy as np
from tqdm.notebook import tqdm

# ============================================
# METRIC FUNCTIONS
# ============================================

def precision_at_k(recommended, actual, k):
    recommended_k = recommended[:k]
    hits = len(set(recommended_k) & set(actual))
    return hits / k

def recall_at_k(recommended, actual, k):
    recommended_k = recommended[:k]
    hits = len(set(recommended_k) & set(actual))
    return hits / len(actual) if len(actual) > 0 else 0

def ndcg_at_k(recommended, actual, k):
    recommended_k = recommended[:k]
    dcg = sum(
        1 / np.log2(i + 2)
        for i, pid in enumerate(recommended_k)
        if pid in actual
    )
    ideal_hits = min(len(actual), k)
    idcg = sum(1 / np.log2(i + 2) for i in range(ideal_hits))
    return dcg / idcg if idcg > 0 else 0

# ============================================
# EVALUATE HYBRID vs BASELINE
# Baseline = pure CF (no nutrition/price layer)
# ============================================

K = 10
eval_users = [u for u in list(ground_truth.keys())[:300]
              if u in user_to_idx]

hybrid_p, hybrid_r, hybrid_n = [], [], []
baseline_p, baseline_r, baseline_n = [], [], []

print(f"Evaluating on {len(eval_users)} users...")

for user_id in tqdm(eval_users):
    actual = list(ground_truth[user_id])

    # --- Hybrid recommendations ---
    hybrid_recs = get_hybrid_recommendations(user_id, n_recommendations=K)
    hybrid_pids = [r['product_id'] for r in hybrid_recs]

    # --- Baseline: pure CF only ---
    cf_recs_raw = get_cf_recommendations(user_id, n_recommendations=K)
    baseline_pids = [pid for pid, _ in cf_recs_raw]

    # --- Score both ---
    hybrid_p.append(precision_at_k(hybrid_pids, actual, K))
    hybrid_r.append(recall_at_k(hybrid_pids, actual, K))
    hybrid_n.append(ndcg_at_k(hybrid_pids, actual, K))

    baseline_p.append(precision_at_k(baseline_pids, actual, K))
    baseline_r.append(recall_at_k(baseline_pids, actual, K))
    baseline_n.append(ndcg_at_k(baseline_pids, actual, K))

print("\n" + "="*50)
print(f"{'Metric':<15} {'Baseline (CF)':>15} {'Hybrid':>15} {'Improvement':>15}")
print("="*50)

metrics = [
    ('Precision@10', baseline_p, hybrid_p),
    ('Recall@10',    baseline_r, hybrid_r),
    ('NDCG@10',      baseline_n, hybrid_n),
]

for name, base, hyb in metrics:
    b = np.mean(base)
    h = np.mean(hyb)
    delta = ((h - b) / b * 100) if b > 0 else 0
    print(f"{name:<15} {b:>15.4f} {h:>15.4f} {delta:>14.1f}%")


