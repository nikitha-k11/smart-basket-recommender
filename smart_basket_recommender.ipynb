# ============================================
# HYBRID SCORING FUNCTION
# ============================================

def get_hybrid_recommendations(user_id, n_recommendations=10):
    """
    Hybrid recommender:
    CF score + nutrition alignment + price alignment
    """
    # Step 1 — Get CF candidates
    cf_recs = get_cf_recommendations(user_id, n_recommendations=50)
    if not cf_recs:
        return []

    # Step 2 — Get user profile
    user_profile = user_features[
        user_features['user_id'] == user_id
    ]
    if user_profile.empty:
        return []

    healthy_ratio = user_profile['healthy_ratio'].values[0]
    budget_ratio = user_profile['budget_ratio'].values[0]

    # Step 3 — Score each candidate
    results = []
    for product_id, cf_score in cf_recs:
        product_info = products_enriched[
            products_enriched['product_id'] == product_id
        ]
        if product_info.empty:
            continue

        nutrition = product_info['nutrition_category'].values[0]
        price_tier = product_info['price_tier'].values[0]
        product_name = product_info['product_name'].values[0]

        # Nutrition score
        if nutrition == 'healthy':
            nutrition_score = healthy_ratio          # reward if user is healthy
        elif nutrition == 'junk':
            nutrition_score = -(healthy_ratio * 0.8) # penalize junk for healthy users
        else:
            nutrition_score = 0.0

        # Price score
        if price_tier == 'budget':
            price_score = budget_ratio               # reward if user is budget
        elif price_tier == 'premium':
            price_score = -(budget_ratio * 0.8)      # penalize premium for budget users
        else:
            price_score = 0.0

        # Final hybrid score
        # CF carries 60% weight, nutrition 25%, price 15%
        hybrid_score = (
            0.60 * cf_score +
            0.25 * nutrition_score * 10 +  # scale to match CF score range
            0.15 * price_score * 10
        )

        results.append({
            'product_id': product_id,
            'product_name': product_name,
            'nutrition': nutrition,
            'price_tier': price_tier,
            'cf_score': round(cf_score, 3),
            'nutrition_score': round(nutrition_score, 3),
            'price_score': round(price_score, 3),
            'hybrid_score': round(hybrid_score, 3)
        })

    # Step 4 — Sort by hybrid score
    results = sorted(results, key=lambda x: x['hybrid_score'], reverse=True)
    return results[:n_recommendations]

